<!DOCTYPE html>
<html lang="en">

<head>
    <%- include("partials/head", { title: "URL Shortener - Dashboard" }) %>
</head>

<body>
    <%- include("partials/header") %>

    <main class="app-main">
        <div class="container">
            <h1>URL Shortener</h1>

            <% if (locals.url) { %>
                <div class="success">
                    Short URL:
                    <a id="shortUrl" href="<%= locals.url %>" target="_blank">
                        <%= locals.url %>
                    </a>
                    <button class="copy-btn" onclick="copyUrl()">Copy</button>
                </div>
            <% } %>

            <div class="card">
                <form class="row-form" method="POST" action="/api" onsubmit="return validateForm()">
                    <input type="text" name="url" id="urlInput" placeholder="https://example.com" required>
                    <button type="submit">Generate</button>
                </form>
            </div>

            <div class="card">
                <% if (locals.urls && locals.urls.length > 0) { %>
                    <table>
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Short</th>
                                <th>Original</th>
                                <th>Clicks</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% locals.urls.forEach((el, index) => { %>
                                <tr>
                                    <td><%= index + 1 %></td>
                                    <td>
                                        <a href="/<%= el.shortId %>" target="_blank"><%= el.shortId %></a>
                                    </td>
                                    <td class="ellipsis-cell">
                                        <a href="<%= el.redirectUrl %>" target="_blank"><%= el.redirectUrl %></a>
                                    </td>
                                    <td><%= el.visitHistory ? el.visitHistory.length : 0 %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                <% } else { %>
                    <p class="empty">No URLs created yet</p>
                <% } %>
            </div>
        </div>
    </main>

    <%- include("partials/footer") %>

    <script>
        function copyUrl() {
            const shortUrlElement = document.getElementById("shortUrl");
            if (!shortUrlElement) return;

            const text = shortUrlElement.innerText;
            navigator.clipboard.writeText(text);
            alert("Copied!");
        }

        function validateForm() {
            const url = document.getElementById("urlInput").value;
            try {
                new URL(url);
                return true;
            } catch {
                alert("Enter a valid URL (include https://)");
                return false;
            }
        }
    </script>
</body>

</html>
